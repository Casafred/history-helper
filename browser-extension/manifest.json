{
  "manifest_version": 3,
  "name": "专利审查文档助手",
  "version": "1.0.0",
  "description": "抓取日本 J-PlatPat 和德国 DPMAregister 的专利审查文档",
  "permissions": ["activeTab", "tabs", "storage", "contextMenus"],
  "host_permissions": [
    "https://www.j-platpat.inpit.go.jp/*",
    "https://register.dpma.de/*",
    "http://localhost:*/"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.j-platpat.inpit.go.jp/*"],
      "js": ["content/jplatpat.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://register.dpma.de/*"],
      "js": ["content/dpma.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png"
  }
}
