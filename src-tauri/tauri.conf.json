{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "专利审查梳理工具",
  "version": "0.1.0",
  "identifier": "com.history-helper.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "专利审查梳理工具",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
